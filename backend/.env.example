PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/devflow
JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_URL=http://127.0.0.1:5173,http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:4000/api/calendar/oauth/callback
AUTH_DISABLED=true
DEV_USER_EMAIL=dev@devflow.local
DEV_USER_NAME=DevFlow Developer
